# ----------------------------------------------------------------------------
# Secrets / connection ONLY. Copy to `.env` and fill in. `.env` is git-ignored.
#
# Everything structural (output paths, file-type rules, diagrams, git/LFS,
# timeouts, etc.) lives in config.yml - NOT here.
# ----------------------------------------------------------------------------

# Base URL MUST include the /wiki suffix.
CONFLUENCE_URL=https://your-site.atlassian.net/wiki
CONFLUENCE_USERNAME=you@example.com
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your_api_token_here
